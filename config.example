# ============================================
# ph-fts based transfer configuration
# ============================================

# Optional namespace. Leave empty to use server-side default behavior.
PH_FTS_NAMESPACE=""

# Recommended for non-interactive automation.
# Leave empty to rely on "ph-fts login" cached state.
PH_FTS_TOKEN=""

# Optional
PH_FTS_ENV="prod"
PH_FTS_PROFILE=""

# Optional remote prefix, e.g. "team/devops".
# If empty, paths start from "releases/..." and "transfer/...".
PH_FTS_REMOTE_ROOT=""

#!/bin/bash

#export http_proxy=http://127.0.0.1:1087;export https_proxy=http://127.0.0.1:1087;export ALL_PROXY=socks5://127.0.0.1:1080

curdir="`dirname $(readlink -f $0)`"
source $curdir/../../lib/common.sh

usage() {
    echo "Usage: $0 [config]" >&2
    echo "  no args : full install" >&2
    echo "  config  : link ~/.config entries only" >&2
}

link_config_entries() {
    local config_src_root="$curdir/.config"
    local config_dst_root="$HOME/.config"

    if [[ ! -d "$config_src_root" ]]; then
        log "Skip .config linking: $config_src_root not found"
        return 0
    fi

    mkdir -p "$config_dst_root"

    while IFS= read -r -d '' src; do
        local name
        name="$(basename "$src")"
        log "Link .config/$name ..."
        _ln "$src" "$config_dst_root/$name"
    done < <(find "$config_src_root" -mindepth 1 -maxdepth 1 -print0 | sort -z)
}

if [[ $# -gt 1 ]]; then
    usage
    exit 1
fi

if [[ $# -eq 1 ]]; then
    if [[ "$1" != "config" ]]; then
        usage
        exit 1
    fi

    log "Configure .config only ..."
    link_config_entries
    log "Done!"
    exit 0
fi

log "Configure bash ..."
_ln $curdir/.bashrc ~/.bashrc
_ln $curdir/.bashrc_custom ~/.bashrc_custom

log "Configure git ..."
_ln $curdir/.gitconfig ~/.gitconfig
_ln $curdir/.gitignore_global ~/.gitignore_global
if [[ ! -e ~/.gitconfig_ignored ]]; then
    cp -f $curdir/.gitconfig_work ~/.gitconfig_work
fi
curl https://raw.githubusercontent.com/git/git/master/contrib/completion/git-completion.bash -o ~/.git-completion.bash

log "Configure tmux ..."
_ln $curdir/.tmux.conf ~/.tmux.conf
_ln $curdir/.tmux-powerlinerc ~/.tmux-powerlinerc

log "Configure .config ..."
link_config_entries

log "Configure codex ..."
mkdir -p ~/.codex
_ln $curdir/ai/config.toml ~/.codex/config.toml
_ln $curdir/ai/AGENTS.md ~/.codex/AGENTS.md

log "Configure claude ..."
mkdir -p ~/.claude
_ln $curdir/ai/AGENTS.md ~/.claude/CLAUDE.md

# font
#git clone https://github.com/supermarin/powerline-fonts.git

brew install shellcheck curl gnu-tar clang-format starship

log "Install codex skills ..."
"$curdir/ai/scripts/install-skills.sh" "$curdir/ai/skills-manifest.json"

# :CocInstall coc-sh
# :CocInstall coc-json

log "Done!"

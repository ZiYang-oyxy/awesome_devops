#!/bin/bash

#export http_proxy=http://127.0.0.1:1087;export https_proxy=http://127.0.0.1:1087;export ALL_PROXY=socks5://127.0.0.1:1080

set -euo pipefail

curdir="$(dirname "$(readlink -f "$0")")"
source "$curdir/../../lib/common.sh"

readonly MODULES=(bash git tmux config ai system)
readonly DEFAULT_MODULES=(bash git tmux config ai system)

tmux_statusd_source_dir() {
    local candidate

    for candidate in \
        "${TMUX_STATUSD_SOURCE_DIR:-}" \
        "/Volumes/code/tmux-statusd" \
        "$curdir/tmux-statusd"
    do
        [[ -n "$candidate" ]] || continue
        if [[ -x "$candidate/scripts/install.sh" ]]; then
            printf '%s\n' "$candidate"
            return 0
        fi
    done

    return 1
}

usage() {
    cat >&2 <<EOF
Usage: $0 [module ...]

Modules:
  bash    link ~/.bashrc and ~/.bashrc_custom
  git     link git config files and refresh git completion
  tmux    link tmux files, link ~/.config/tmux, and build tmux-statusd if possible
  config  link all entries under ~/.config
  ai      link codex/claude config and install codex skills
  system  install Homebrew packages used by these dotfiles

Examples:
  $0
  $0 bash
  $0 bash git
  $0 config
  $0 --list
EOF
}

list_modules() {
    cat <<EOF
bash    link ~/.bashrc and ~/.bashrc_custom
git     link git config files and refresh git completion
tmux    link tmux files, link ~/.config/tmux, and build tmux-statusd if possible
config  link all entries under ~/.config
ai      link codex/claude config and install codex skills
system  install Homebrew packages used by these dotfiles
EOF
}

is_valid_module() {
    local module="$1"
    local item

    for item in "${MODULES[@]}"; do
        if [[ "$item" == "$module" ]]; then
            return 0
        fi
    done

    return 1
}

append_unique_module() {
    local module="$1"
    local item

    if [[ ${#selected_modules[@]} -gt 0 ]]; then
        for item in "${selected_modules[@]}"; do
            if [[ "$item" == "$module" ]]; then
                return 0
            fi
        done
    fi

    selected_modules+=("$module")
}

link_config_entry() {
    local name="$1"
    local config_src_root="$curdir/.config"
    local config_dst_root="$HOME/.config"
    local src="$config_src_root/$name"

    if [[ ! -e "$src" ]]; then
        log_warn "Skip .config/$name linking: $src not found"
        return 0
    fi

    mkdir -p "$config_dst_root"
    log_info "Link .config/$name ..."
    _ln "$src" "$config_dst_root/$name"
}

link_config_entries() {
    local config_src_root="$curdir/.config"
    local config_dst_root="$HOME/.config"

    if [[ ! -d "$config_src_root" ]]; then
        log_warn "Skip .config linking: $config_src_root not found"
        return 0
    fi

    mkdir -p "$config_dst_root"

    while IFS= read -r -d '' src; do
        local name
        name="$(basename "$src")"
        log_info "Link .config/$name ..."
        _ln "$src" "$config_dst_root/$name"
    done < <(find "$config_src_root" -mindepth 1 -maxdepth 1 -print0 | sort -z)
}

install_bash() {
    log_info "Configure bash ..."
    _ln "$curdir/.bashrc" "$HOME/.bashrc"
    _ln "$curdir/.bashrc_custom" "$HOME/.bashrc_custom"
}

install_git() {
    log_info "Configure git ..."
    _ln "$curdir/.gitconfig" "$HOME/.gitconfig"
    _ln "$curdir/.gitignore_global" "$HOME/.gitignore_global"

    if [[ ! -e "$HOME/.gitconfig_ignored" ]]; then
        if [[ -e "$curdir/.gitconfig_work" ]]; then
            cp -f "$curdir/.gitconfig_work" "$HOME/.gitconfig_work"
        else
            log_warn "Skip ~/.gitconfig_work initialization: $curdir/.gitconfig_work not found"
        fi
    fi

    curl https://raw.githubusercontent.com/git/git/master/contrib/completion/git-completion.bash -o "$HOME/.git-completion.bash"
}

install_tmux() {
    local tmux_statusd_src

    log_info "Configure tmux ..."
    _ln "$curdir/.tmux.conf" "$HOME/.tmux.conf"
    _ln "$curdir/.tmux-powerlinerc" "$HOME/.tmux-powerlinerc"
    link_config_entry "tmux"

    tmux_statusd_src="$(tmux_statusd_source_dir || true)"
    if command -v go >/dev/null 2>&1 && [[ -n "$tmux_statusd_src" ]]; then
        log_info "Build tmux-statusd ..."
        "$tmux_statusd_src/scripts/install.sh" "$HOME/bin"
    elif [[ -z "$tmux_statusd_src" ]]; then
        log_warn "Skip tmux-statusd build: source repo not present"
    else
        log_warn "Skip tmux-statusd build: go not found"
    fi
}

install_config() {
    log_info "Configure .config ..."
    link_config_entries
}

install_ai() {
    log_info "Configure codex ..."
    mkdir -p "$HOME/.codex"
    _ln "$curdir/ai/config.toml" "$HOME/.codex/config.toml"
    _ln "$curdir/ai/AGENTS.md" "$HOME/.codex/AGENTS.md"

    log_info "Configure claude ..."
    mkdir -p "$HOME/.claude"
    _ln "$curdir/ai/AGENTS.md" "$HOME/.claude/CLAUDE.md"

    if command -v npx >/dev/null 2>&1; then
        log_info "Install codex skills ..."
        "$curdir/ai/scripts/install-skills.sh" "$curdir/ai/skills-manifest.json"
    else
        log_warn "Skip codex skills install: npx not found"
    fi
}

install_system() {
    if ! command -v brew >/dev/null 2>&1; then
        log_warn "Skip system packages: brew not found"
        return 0
    fi

    log_info "Install system packages ..."
    brew install shellcheck curl gnu-tar clang-format starship
}

run_module() {
    local module="$1"

    case "$module" in
        bash)
            install_bash
            ;;
        git)
            install_git
            ;;
        tmux)
            install_tmux
            ;;
        config)
            install_config
            ;;
        ai)
            install_ai
            ;;
        system)
            install_system
            ;;
        *)
            log_error "Unknown module: $module"
            exit 1
            ;;
    esac
}

selected_modules=()

if [[ $# -eq 0 ]]; then
    selected_modules=("${DEFAULT_MODULES[@]}")
else
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -h|--help)
                usage
                exit 0
                ;;
            --list)
                list_modules
                exit 0
                ;;
            *)
                if ! is_valid_module "$1"; then
                    log_error "Unknown module: $1"
                    usage
                    echo >&2
                    list_modules >&2
                    exit 1
                fi
                append_unique_module "$1"
                ;;
        esac
        shift
    done
fi

for module in "${selected_modules[@]}"; do
    run_module "$module"
done

log_info "Done!"

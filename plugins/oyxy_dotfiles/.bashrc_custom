_cx_run() {
  command -v gh >/dev/null 2>&1
  if [ $? -eq 0 ]; then
    local gh_token
    gh_token="$(gh auth token 2>/dev/null || true)"
    if [ -n "$gh_token" ]; then
      export GITHUB_PAT_TOKEN="$gh_token"
      export GH_TOKEN="$gh_token"
    fi
  fi

  local trust_root
  local trust_root_escaped
  local provider_base_url
  local provider_base_url_escaped
  local -a cx_flags=()
  local -a cx_env=()

  if command -v git >/dev/null 2>&1; then
    trust_root="$(git rev-parse --show-toplevel 2>/dev/null || true)"
  fi
  if [ -z "$trust_root" ]; then
    trust_root="$(pwd -P 2>/dev/null || pwd)"
  fi
  trust_root_escaped="${trust_root//\\/\\\\}"
  trust_root_escaped="${trust_root_escaped//\"/\\\"}"
  cx_flags+=(
    "-c"
    "projects={\"${trust_root_escaped}\"={ trust_level = \"trusted\" }}"
  )

  if [ "${T:-0}" = "1" ]; then
    [ -n "${T_OPENAI_API_KEY:-}" ] && cx_env+=("OPENAI_API_KEY=$T_OPENAI_API_KEY")
    provider_base_url="${T_OPENAI_BASE_URL:-}"
  else
    [ -n "${OPENAI_API_KEY:-}" ] && cx_env+=("OPENAI_API_KEY=$OPENAI_API_KEY")
    provider_base_url="${OPENAI_BASE_URL:-}"
  fi

  if [ -n "$provider_base_url" ]; then
    provider_base_url_escaped="${provider_base_url//\\/\\\\}"
    provider_base_url_escaped="${provider_base_url_escaped//\"/\\\"}"
    cx_flags+=(
      "-c"
      "model_providers.openai-http.base_url=\"${provider_base_url_escaped}\""
    )
  fi

  if [ "${#cx_env[@]}" -eq 0 ]; then
    echo "missing OPENAI_API_KEY: set T=1 T_OPENAI_API_KEY=... for one-shot runs, or export OPENAI_API_KEY in your shell" >&2
    return 1
  fi

  env -u OPENAI_BASE_URL "${cx_env[@]}" codex "${cx_flags[@]}" "$@"
}


CURDIR="`dirname $(readlink -f $0)`"

_env_ph_fts_namespace="${PH_FTS_NAMESPACE-}"
_env_ph_fts_token="${PH_FTS_TOKEN-}"
_env_ph_fts_env="${PH_FTS_ENV-}"
_env_ph_fts_profile="${PH_FTS_PROFILE-}"
_env_ph_fts_remote_root="${PH_FTS_REMOTE_ROOT-}"
_env_has_ph_fts_namespace="${PH_FTS_NAMESPACE+x}"
_env_has_ph_fts_token="${PH_FTS_TOKEN+x}"
_env_has_ph_fts_env="${PH_FTS_ENV+x}"
_env_has_ph_fts_profile="${PH_FTS_PROFILE+x}"
_env_has_ph_fts_remote_root="${PH_FTS_REMOTE_ROOT+x}"

source $CURDIR/lib/common.sh
if [[ -f "$CURDIR/config" ]]; then
    source "$CURDIR/config"
fi
[[ -n "$_env_has_ph_fts_namespace" ]] && PH_FTS_NAMESPACE="$_env_ph_fts_namespace"
[[ -n "$_env_has_ph_fts_token" ]] && PH_FTS_TOKEN="$_env_ph_fts_token"
[[ -n "$_env_has_ph_fts_env" ]] && PH_FTS_ENV="$_env_ph_fts_env"
[[ -n "$_env_has_ph_fts_profile" ]] && PH_FTS_PROFILE="$_env_ph_fts_profile"
[[ -n "$_env_has_ph_fts_remote_root" ]] && PH_FTS_REMOTE_ROOT="$_env_ph_fts_remote_root"

EXTERNAL_ROOT="${AD_EXTERNAL_DIR:-$CURDIR/../ad_external/awesome_devops}"
if [[ ! -d "$EXTERNAL_ROOT" ]]; then
    EXTERNAL_ROOT=""
fi

if [[ -z "$AD_DISABLE_EXTERNAL_AD" ]] && [[ -z "$AD_EXTERNAL_AD_PASSTHRU" ]] && [[ -n "$EXTERNAL_ROOT" ]] && [[ -x "$EXTERNAL_ROOT/ad" ]]; then
    _external_ad_real="$(readlink -f "$EXTERNAL_ROOT/ad")"
    _self_ad_real="$(readlink -f "$0")"
    if [[ "$_external_ad_real" != "$_self_ad_real" ]]; then
        AD_EXTERNAL_AD_PASSTHRU=1 AD_BASE_AD="$_self_ad_real" AD_EXTERNAL_DIR="$EXTERNAL_ROOT" exec "$EXTERNAL_ROOT/ad" "$@"
    fi
fi

merge_dir_entries()
{
    _relative_path="$1"
    {
        ls "$CURDIR/$_relative_path" 2> /dev/null
        if [[ -n "$EXTERNAL_ROOT" ]]; then
            ls "$EXTERNAL_ROOT/$_relative_path" 2> /dev/null
        fi
    } | awk 'NF' | sort -u
}

resolve_plugin_install()
{
    _plugin_name="$1"
    if [[ -f "$CURDIR/plugins/$_plugin_name/install" ]]; then
        echo "$CURDIR/plugins/$_plugin_name/install"
        return 0
    fi
    if [[ -n "$EXTERNAL_ROOT" ]] && [[ -f "$EXTERNAL_ROOT/plugins/$_plugin_name/install" ]]; then
        echo "$EXTERNAL_ROOT/plugins/$_plugin_name/install"
        return 0
    fi
    return 1
}


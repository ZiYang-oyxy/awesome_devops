        return 0
    fi
    return 1
}

resolve_tool_suite_dir()
{
    _tool_name="$1"
    if [[ -d "$CURDIR/tools/$_tool_name" ]]; then
        echo "$CURDIR/tools/$_tool_name"
        return 0
    fi
    if [[ -d "$CURDIR/ext_tools/$_tool_name" ]]; then
        echo "$CURDIR/ext_tools/$_tool_name"
        return 0
    fi
    if [[ -n "$EXTERNAL_ROOT" ]] && [[ -d "$EXTERNAL_ROOT/tools/$_tool_name" ]]; then
        echo "$EXTERNAL_ROOT/tools/$_tool_name"
        return 0
    fi
    if [[ -n "$EXTERNAL_ROOT" ]] && [[ -d "$EXTERNAL_ROOT/ext_tools/$_tool_name" ]]; then
        echo "$EXTERNAL_ROOT/ext_tools/$_tool_name"
        return 0
    fi
    return 1
}

trim_trailing_slash()
{
    _path="$1"
    while [[ "$_path" == */ ]]; do
        _path="${_path%/}"
    done
    echo "$_path"
}

join_remote_path()
{
    _prefix="$1"
    _leaf="$2"
    if [[ -z "$_prefix" ]]; then
        echo "$_leaf"
    elif [[ -z "$_leaf" ]]; then
        echo "$_prefix"
    else
        echo "${_prefix}/${_leaf}"
    fi
}

is_explicit_remote_path()
{
    _path="$1"
    [[ "$_path" == */* ]] || [[ "$_path" == ./* ]] || [[ "$_path" == ../* ]]
}

ph_fts_release_root()
{
    _root="$(trim_trailing_slash "${PH_FTS_REMOTE_ROOT:-}")"
    if [[ -n "$_root" ]]; then
        echo "${_root}/releases/awesome_devops"
    else
        echo "releases/awesome_devops"
    fi
}

ph_fts_transfer_files_root()
{
    _root="$(trim_trailing_slash "${PH_FTS_REMOTE_ROOT:-}")"
    if [[ -n "$_root" ]]; then
        echo "${_root}/transfer/files"
    else
        echo "transfer/files"
    fi
}

ph_fts_transfer_dirs_root()
{
    _root="$(trim_trailing_slash "${PH_FTS_REMOTE_ROOT:-}")"
    if [[ -n "$_root" ]]; then
        echo "${_root}/transfer/dirs"
    else
        echo "transfer/dirs"
    fi
}

release_version_root()
{
    join_remote_path "$(ph_fts_release_root)" "$1"
}

release_tar_remote()
{
    join_remote_path "$(release_version_root "$1")" "awesome_devops.tar"
}

release_install_remote()
{
    join_remote_path "$(release_version_root "$1")" "install.sh"
}

release_latest_remote()
{
    join_remote_path "$(ph_fts_release_root)" "latest_version"
}

release_not_in_ad_tar_remote()
{
    join_remote_path "$(release_version_root "$1")" "not_in_ad_tar/$2"
}

build_file_remote_target()
{
    _input="$1"
    if is_explicit_remote_path "$_input"; then
        echo "$_input"
    else
        join_remote_path "$(ph_fts_transfer_files_root)" "$_input"
    fi
}

build_dir_remote_target()
{
    _input="$1"
    if [[ "$_input" != *.tgz ]]; then
        _input="${_input}.tgz"
    fi
    if is_explicit_remote_path "$_input"; then
        echo "$_input"
    else
        join_remote_path "$(ph_fts_transfer_dirs_root)" "$_input"
    fi
}

ph_fts_build_args()
{
    PH_FTS_ARGS=()
    [[ -n "$PH_FTS_ENV" ]] && PH_FTS_ARGS+=(-e "$PH_FTS_ENV")
    [[ -n "$PH_FTS_PROFILE" ]] && PH_FTS_ARGS+=(--profile "$PH_FTS_PROFILE")
    [[ -n "$PH_FTS_NAMESPACE" ]] && PH_FTS_ARGS+=(-n "$PH_FTS_NAMESPACE")
    [[ -n "$PH_FTS_TOKEN" ]] && PH_FTS_ARGS+=(-t "$PH_FTS_TOKEN")
}

require_ph_fts()
{
    if ! type ph-fts >/dev/null 2>&1; then
        cecho -R "ph-fts command not found"
        exit 1
    fi
    if [[ -z "$PH_FTS_TOKEN" ]] && [[ -z "$PH_FTS_PROFILE" ]]; then
        cecho -Y "PH_FTS_TOKEN is empty, fallback to ph-fts cached login state"
    fi
    ph_fts_build_args
}

ph_fts_upload_file()
{
    ph-fts upload "${PH_FTS_ARGS[@]}" -L "$1" -R "$2"
}

run_ph_fts_upload_gray_stream()
{
    printf '\033[38;5;8m'
    ph_fts_upload_file "$1" "$2"
    _ret=$?
    printf '\033[0m'
    return $_ret
}

ph_fts_download_file()
{
    ph-fts download "${PH_FTS_ARGS[@]}" -L "$1" -R "$2"
}

run_ph_fts_download_gray_stream()
{
    printf '\033[38;5;8m'
    ph_fts_download_file "$1" "$2"
    _ret=$?
    printf '\033[0m'
    return $_ret
}

ph_fts_try_download()
{
    require_ph_fts
    _local_file="$1"
    shift
    PH_FTS_LAST_REMOTE=""
    for _candidate in "$@"; do
        [[ -z "$_candidate" ]] && continue
        if run_ph_fts_download_gray_stream "$_local_file" "$_candidate"; then
            PH_FTS_LAST_REMOTE="$_candidate"
            return 0
        fi
    done
    return 1
}

put()
{
    require_ph_fts
    if [[ ! -f "$1" ]]; then
        cecho -R "No such file"
        exit 1
    fi
    _name="$(basename "$1")"
    _r_file="$(build_file_remote_target "${2:-$_name}")"
    if ! run_ph_fts_upload_gray_stream "$1" "$_r_file"; then
        cecho -R "Upload failed"
        exit 1
    fi
    _res=(`md5sum "$1"`)
    cecho -Y "${_res[0]}"
    cecho -G "$_r_file"
    cecho -M "ad get $_r_file"
}

# [Comparison of Compression Algorithms]
# https://linuxreviews.org/Comparison_of_Compression_Algorithms
dput()
{
    require_ph_fts
    # “:”会被tar认为是远程服务器
    if [[ $1 =~ .*:.* ]]; then
        cecho -R "not allow directory contain \":\""
        exit 1
    fi
    if [[ ! -d "$1" ]]; then
        cecho -R "No such directory"
        exit 1
    fi
    _name="$(basename "$1")"
    _parent="$(dirname "$1")"
    _r_file="$(build_dir_remote_target "${2:-$_name}")"
    if (type pigz >/dev/null 2>&1); then
        tar --no-xattrs -c -C "$_parent" --exclude='.git' -f - "$_name" | pigz > "$_name.tgz"
    else
        tar --no-xattrs -c -C "$_parent" --exclude='.git' -z -f "$_name.tgz" "$_name"
    fi
    if ! run_ph_fts_upload_gray_stream "$_name.tgz" "$_r_file"; then
        cecho -R "Upload failed"
        rm -f "$_name.tgz"
        exit 1
    fi
    _res=(`md5sum "$_name.tgz"`)
    cecho -Y "${_res[0]}"
    cecho -G "$_r_file"
    cecho -M "ad dget $_r_file"
    rm -f "$_name.tgz"
}


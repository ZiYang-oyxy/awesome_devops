tput()
{
    require_ph_fts
    if [[ ! -f "$1" ]]; then
        cecho -R "No such file"
        exit 1
    fi
    _name="$(basename "$1")"
    _r_name="`date '+%Y-%m-%d_%H-%M-%S'`_${2:-$_name}"
    _r_file="$(build_file_remote_target "$_r_name")"
    if ! run_ph_fts_upload_gray_stream "$1" "$_r_file"; then
        cecho -R "Upload failed"
        exit 1
    fi
    _res=(`md5sum "$1"`)
    cecho -Y "${_res[0]}"
    cecho -G "$_r_file"
    cecho -M "ad get $_r_file"
}

get()
{
    _remote_input="$1"
    if [[ -n "$2" ]]; then
        _l_file="$2"
    else
        _l_file="$(basename "$_remote_input")"
    fi
    temp_file="${_l_file}.download"
    _download_candidates=()
    if is_explicit_remote_path "$_remote_input"; then
        _download_candidates+=("$_remote_input")
    else
        _download_candidates+=("$(build_file_remote_target "$_remote_input")")
        _download_candidates+=("$_remote_input")
    fi
    if ! ph_fts_try_download "$temp_file" "${_download_candidates[@]}"; then
        rm -f "$temp_file"
        cecho -R "Download failed"
        exit 1
    fi

    owner=""
    if [ -f "$_l_file" ]; then
        owner=$(stat -c "%U:%G" "$_l_file")
        permissions=$(stat -c "%a" "$_l_file")
    fi
    mv -f "$temp_file" "$_l_file"
    if [[ -n $owner ]]; then
        chown "$owner" "$_l_file"
        chmod "$permissions" "$_l_file"
    fi
    _res=(`md5sum "$_l_file"`)
    cecho -Y "${_res[0]}"
    cecho -G "$(readlink -f "$_l_file")"
}

dget()
{
    # “:”会被tar认为是远程服务器
    if [[ "$1" == *":"* ]]; then
        cecho -R 'filename must not contain ":"'
        exit 1
    fi

    _remote_input="$1"
    _download_candidates=()
    if is_explicit_remote_path "$_remote_input"; then
        if [[ "$_remote_input" == *.tgz ]]; then
            _download_candidates+=("$_remote_input")
        else
            _download_candidates+=("${_remote_input}.tgz")
        fi
    else
        if [[ "$_remote_input" == *.tgz ]]; then
            _download_candidates+=("$(build_dir_remote_target "$_remote_input")")
            _download_candidates+=("$_remote_input")
        else
            _download_candidates+=("$(build_dir_remote_target "$_remote_input")")
            _download_candidates+=("${_remote_input}.tgz")
        fi
    fi

    _selected_remote=""
    for _candidate in "${_download_candidates[@]}"; do
        if [[ -n "$_candidate" ]]; then
            _selected_remote="$_candidate"
            break
        fi
    done
    _local_tgz="$(basename "$_selected_remote")"
    _temp_file_path="${_local_tgz}.download"

    if ph_fts_try_download "$_temp_file_path" "${_download_candidates[@]}"; then
        _selected_remote="$PH_FTS_LAST_REMOTE"
        _local_tgz="$(basename "$_selected_remote")"
        mv -f "$_temp_file_path" "$_local_tgz"
        tar -x -o -f "$_local_tgz"
        cecho -Y "$(md5sum "$_local_tgz" | awk '{print $1}')"
        _display_dir="$(basename "$_local_tgz" .tgz)"
        cecho -G "$(readlink -f "$_display_dir")"
        rm -f "$_local_tgz"
    else
        rm -f "$_temp_file_path"
        cecho -R "Download failed"
        exit 1
    fi
}

upgrade()
{
    require_ph_fts
    _tmp_dir="$(mktemp -d)"
    _latest_file="$_tmp_dir/latest_version"
    _install_file="$_tmp_dir/install.sh"
    _latest_remote="$(release_latest_remote)"
    if ! ph_fts_try_download "$_latest_file" "$_latest_remote" "@latest_version@"; then
        rm -rf "$_tmp_dir"
        cecho -R "Unable to download latest_version"
        exit 1
    fi
    _latest_ver="$(tr -d '\r\n' < "$_latest_file")"
    _install_candidates=()
    if [[ -n "$_latest_ver" ]]; then
        _install_candidates+=("$(release_install_remote "$_latest_ver")")
    fi
    _install_candidates+=("@aadi@")
    if ! ph_fts_try_download "$_install_file" "${_install_candidates[@]}"; then
        rm -rf "$_tmp_dir"
        cecho -R "Unable to download install script"
        exit 1
    fi
    bash "$_install_file"
    rm -rf "$_tmp_dir"
}


        echo "$EXTERNAL_ROOT/tools/$_tool_name"
        return 0
    fi
    if [[ -n "$EXTERNAL_ROOT" ]] && [[ -f "$EXTERNAL_ROOT/ext_tools/$_tool_name" ]]; then
        echo "$EXTERNAL_ROOT/ext_tools/$_tool_name"
        return 0
    fi
    return 1
}

